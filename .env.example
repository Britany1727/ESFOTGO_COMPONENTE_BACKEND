
# === MONGODB ATLAS ===
MONGODB_URI_PRODUCTION=mongodb+srv://<user>:<password>@cluster.esfotgo.mongodb.net/esfotgo

# === JWT ===
JWT_SECRET=your_access_token_secret_key_here
JWT_REFRESH_SECRET=your_refresh_token_secret_key_here

# === CLOUDINARY ===
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# === SMTP (Mailtrap / Gmail / Outlook) ===
HOST_MAILTRAP=smtp.gmail.com
PORT_MAILTRAP=465
USER_MAILTRAP=your_email@gmail.com
PASS_MAILTRAP=your_app_password

# === RESEND (alternativa email) ===
RESEND_API_KEY=your_resend_api_key

# === URLS ===
URL_BACKEND=http://localhost:3000/api/
URL_FRONTEND=http://localhost:5173/

# === SERVER ===
PORT=3000
